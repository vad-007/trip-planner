# Environment Configuration Example
# 
# Copy this file to .env and fill in your values
# DO NOT commit .env file to version control (it contains secrets)
#
# Format:
#   - Lines starting with # are comments (ignored)
#   - Empty lines are ignored
#   - Format: KEY=VALUE (no spaces around =)
#   - String values don't need quotes

# ============================================================================
# GOOGLE API CONFIGURATION
# ============================================================================

# Google API Key for search functionality
# Get from: https://console.cloud.google.com/
# Required for: Google Search API, Gemini API
GOOGLE_API_KEY=your_google_api_key_here

# Timeout for Google API calls (seconds)
# Increase if you have slow internet, decrease if you want faster failures
GOOGLE_API_TIMEOUT=10


# ============================================================================
# LARGE LANGUAGE MODEL (LLM) CONFIGURATION
# ============================================================================

# Which LLM model to use
# Options: 'gemini-2.5-flash' (recommended), 'gemini-1.5-flash', 'gemini-1.5-pro'
# For cost optimization, use flash models
LLM_MODEL=gemini-2.5-flash

# LLM timeout (seconds) for each request
LLM_TIMEOUT=30

# Temperature for LLM responses (0.0-1.0)
# Lower = more deterministic, Higher = more creative
# Recommended for travel: 0.7 (balanced)
AGENT_TEMPERATURE=0.7


# ============================================================================
# CACHE CONFIGURATION
# ============================================================================

# Enable/disable caching system
# Set to 'true' for production, 'false' for testing
ENABLE_CACHING=true

# Default TTL (Time-To-Live) for cached items in hours
# How long before cache entries expire and are refreshed
CACHE_DEFAULT_TTL_HOURS=48

# TTL for destination data (cached for longer, changes infrequently)
# 720 hours = 30 days
CACHE_DESTINATION_TTL_HOURS=720

# TTL for search results (cached shorter, may change frequently)
# 48 hours = 2 days
CACHE_SEARCH_TTL_HOURS=48

# Path to cache database
# Default: trip_planner/.cache/trip_cache.db
# Leave empty to use default location
CACHE_DB_PATH=


# ============================================================================
# TOOL CONFIGURATION
# ============================================================================

# Enable/disable Google Search tool
# Set to 'true' to use Google Search as fallback (costs API)
# Set to 'false' to only use local database (cheaper, limited functionality)
ENABLE_GOOGLE_SEARCH=true

# Enable/disable local destination database
# Set to 'true' to use pre-indexed 100+ destinations (free, fast)
# Set to 'false' to only use Google Search (expensive, complete)
ENABLE_DESTINATION_DB=true

# Geolocation search settings
# Radius for nearby place searches (in meters)
GEO_SEARCH_RADIUS_METERS=3000

# Maximum results for place searches
GEO_SEARCH_LIMIT=5

# User agent for Nominatim (OpenStreetMap)
# Keep this as is (required by OpenStreetMap terms)
NOMINATIM_USER_AGENT=adk_trip_planner


# ============================================================================
# DEVELOPMENT & DEBUGGING
# ============================================================================

# Environment type: 'development', 'production', or 'testing'
# Affects default values for cache TTL, timeouts, logging
ENVIRONMENT=development

# Enable debug mode for verbose output
# Set to 'true' for development, 'false' for production
DEBUG_MODE=false

# Enable statistics logging (tracks cache hits, API calls, response times)
# Set to 'true' to monitor performance
ENABLE_STATS_LOGGING=true

# Maximum agents to use per query
# Lower = cheaper, Higher = better quality (usually)
MAX_AGENTS_PER_QUERY=2


# ============================================================================
# OPTIONAL: API CREDENTIALS FOR EXTENDED FEATURES
# ============================================================================

# OpenWeather API (optional, for real-time weather)
# Get from: https://openweathermap.org/api
OPENWEATHER_API_KEY=

# Optional: Your custom destination database
# Path to JSON file with additional destinations
CUSTOM_DESTINATIONS_DB_PATH=


# ============================================================================
# NOTES
# ============================================================================
#
# Cost Optimization Tips:
# 1. Keep ENABLE_DESTINATION_DB=true (free, fast)
# 2. Keep ENABLE_GOOGLE_SEARCH=true but it's only used as fallback
# 3. Use longer TTL values for production (CACHE_DESTINATION_TTL_HOURS=720)
# 4. Disable ENABLE_STATS_LOGGING in production if you don't need metrics
#
# Development vs Production:
# - ENVIRONMENT=development: Shorter cache TTL, all features enabled, debug output
# - ENVIRONMENT=production: Longer cache TTL, optimized settings, minimal output
#
# First Run:
# 1. Copy this file to .env: cp .env.example .env
# 2. Fill in your GOOGLE_API_KEY
# 3. Leave other values as default to start
# 4. Test the system and adjust as needed
#
# Security Note:
# - Never commit .env file to version control
# - Never share your GOOGLE_API_KEY
# - Add .env to .gitignore
